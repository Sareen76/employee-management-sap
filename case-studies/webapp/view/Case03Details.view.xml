<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  controllerName="com.capgemini.casestudies.controller.Case03Details">

  <Page title="Sales Order Details">

    <ObjectHeader
      title="Order #{OrderID}"
      number="{Freight}"
      numberUnit="USD"/>

    <Table items="{Order_Details}">
      <columns>
        <Column><Text text="Product"/></Column>
        <Column><Text text="Quantity"/></Column>
        <Column><Text text="Unit Price"/></Column>
      </columns>

      <items>
        <ColumnListItem>
          <cells>
            <Text text="{Product/ProductName}"/>
            <Text text="{Quantity}"/>
            <Text text="{UnitPrice}"/>
          </cells>
        </ColumnListItem>
      </items>
    </Table>

  </Page>
</mvc:View>
