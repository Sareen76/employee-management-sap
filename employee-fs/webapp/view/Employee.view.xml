<mvc:View
    controllerName="com.capgemini.employeefs.controller.Employee"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <subHeader>
            <Toolbar>
                <Title text="Employees" />
                <ToolbarSpacer />
                <SearchField
                    width="20rem"
                    liveChange=".onSearch"
                    placeholder="Search by name or title"
                />

                
<ToolbarSpacer />

            <!-- Sort Buttons -->
            <Button icon="sap-icon://sort-ascending" press=".onSortAsc"/>
            <Button icon="sap-icon://sort-descending" press=".onSortDesc"/>

            <!-- Filter Button -->
            <Button icon="sap-icon://filter" press=".onFilterDialog"/>

            </Toolbar>
        </subHeader>
        <content>
            <Table
                id="empTable"
                items="{path: '/Employees'}"
                mode="MultiSelect"
                includeItemInSelection="false"
                growing="true"
                itemPress=".onItemPress"
                growingScrollToLoad="true"
            >
                <columns>
    <Column>
        <Label text="First Name" />
    </Column>
    <Column>
        <Label text="Last Name" />
    </Column>
    <Column>
        <Label text="Email" />
    </Column>
    <Column>
        <Label text="Job Title" />
    </Column>
    <Column>
        <Label text="Status" />
    </Column>
    <Column>
        <Label text="Hire Date" />
    </Column>
</columns>
                <items>
                    <ColumnListItem type="Active">
                        <Text text="{FirstName}" />
                        <Text text="{LastName}" />
                        <Text text="{Email}" />
                        <Text text="{JobTitle}" />

                        <ObjectStatus
                            text="{Status}"
                            state="{= ${Status} === 'Active' ? 'Success' : 'Warning'}"
                        />
                        <Text
                            text="{path: 'HireDate', type: 'sap.ui.model.odata.type.Date'}"
                        />
                    </ColumnListItem>
                </items>
            </Table>
            <HBox id="AddEmployee" class="sapUiSmallMarginTop">
              <Button icon="sap-icon://add" type="Emphasized" press=".onCreate" text="Add New Employee"/>
              <Button icon="sap-icon://upload"  text="Upload Excel" press=".onUploadExcel"/>
              <Button icon="sap-icon://delete" text="Batch Delete" press=".onBatchDelete" />
              <Button icon="sap-icon://download" text="Download PDF" press=".onDownloadPDF"/>
            </HBox>
        </content>
    </Page>
</mvc:View>
