<c:FragmentDefinition
    xmlns="sap.m"
    xmlns:c="sap.ui.core"
    xmlns:core="sap.ui.core">

    <Dialog id="EmployeeDialog"
            title="{vm>/dialogTitle}"
            stretchOnPhone="true">

        <VBox class="sapUiSmallMargin">

            <Label text="First Name" required="true"/>
            <Input value="{dlg>/FirstName}"/>

            <Label text="Last Name" required="true"/>
            <Input value="{dlg>/LastName}"/>

            <Label text="Email" required="true"/>
            <Input value="{dlg>/Email}"/>

            <Label text="Job Title"/>
            <Input value="{dlg>/JobTitle}"/>

            <Label text="Status"/>
            <SegmentedButton selectedKey="{dlg>/Status}">
                <items>
                    <SegmentedButtonItem key="Active" text="Active"/>
                    <SegmentedButtonItem key="OnLeave" text="On Leave"/>
                </items>
            </SegmentedButton>

            <Label text="Hire Date"/>
            <DatePicker
                value="{dlg>/HireDate}"
                valueFormat="yyyy-MM-dd"
                displayFormat="yyyy-MM-dd"
                placeholder="YYYY-MM-DD"
                required="true"/>

            <Label text="Department"/>
            <Select selectedKey="{dlg>/Department_ID}"
                    items="{ path: '/Departments' }">
                <core:Item key="{ID}" text="{Name}"/>
            </Select>

        </VBox>

        <beginButton>
            <Button text="{= ${vm>/mode} === 'CREATE' ? 'Create' : 'Save'}"
                    press=".onDialogSave"/>
        </beginButton>

        <endButton>
            <Button text="Cancel"
                    type="Reject"
                    press=".onDialogCancel"/>
        </endButton>

    </Dialog>

</c:FragmentDefinition>